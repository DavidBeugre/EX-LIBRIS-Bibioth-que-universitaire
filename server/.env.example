# consultables via GET /api/notifications/outbox) plutôt qu'envoyés réellement.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Ex Libris <bibliotheque@universite.ci>"
