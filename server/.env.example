DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/exlibris?schema=public"
JWT_SECRET="change_this_secret_in_production"
JWT_EXPIRES_IN="8h"
PORT=4000
PENALITE_PAR_JOUR=0.50

